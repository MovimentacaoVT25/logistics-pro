<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Autenticando... | Logistics Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@supabase/supabase-js@2"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'sans-serif'],
                    },
                },
            },
        }
    </script>
    
    <style>
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0c4a6e 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .loader {
            width: 60px;
            height: 60px;
            border: 4px solid rgba(14, 165, 233, 0.2);
            border-top-color: #0ea5e9;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        .pulse-ring {
            position: absolute;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 2px solid rgba(14, 165, 233, 0.3);
            animation: pulse-ring 2s ease-out infinite;
        }
        
        @keyframes pulse-ring {
            0% {
                transform: scale(0.8);
                opacity: 1;
            }
            100% {
                transform: scale(1.5);
                opacity: 0;
            }
        }
    </style>
</head>
<body class="font-sans antialiased">

    <div class="text-center">
        <div class="relative inline-flex items-center justify-center mb-8">
            <div class="pulse-ring"></div>
            <div class="pulse-ring" style="animation-delay: 0.5s;"></div>
            <div class="loader"></div>
        </div>
        
        <h1 class="text-2xl font-bold text-white mb-2">Autenticando...</h1>
        <p class="text-slate-400">Aguarde enquanto processamos seu login</p>
        
        <div id="statusMessage" class="mt-6 text-sm"></div>
    </div>

    <script src="/js/auth.js"></script>
    <script>
        // Processar callback de autenticação
        document.addEventListener('DOMContentLoaded', async () => {
            const statusMessage = document.getElementById('statusMessage');
            
            try {
                statusMessage.innerHTML = '<span class="text-primary-400">Verificando sessão...</span>';
                
                // Aguardar um momento para o Supabase processar o hash
                setTimeout(async () => {
                    try {
                        const { data, error } = await supabase.auth.getSession();
                        
                        if (error) {
                            throw error;
                        }
                        
                        if (data.session) {
                            statusMessage.innerHTML = '<span class="text-emerald-400">Login realizado com sucesso!</span>';
                            
                            setTimeout(() => {
                                window.location.href = '/app.html';
                            }, 1000);
                        } else {
                            statusMessage.innerHTML = '<span class="text-rose-400">Sessão não encontrada. Redirecionando...</span>';
                            
                            setTimeout(() => {
                                window.location.href = '/login.html';
                            }, 2000);
                        }
                    } catch (innerError) {
                        console.error('Erro ao processar callback:', innerError);
                        statusMessage.innerHTML = '<span class="text-rose-400">Erro na autenticação. Redirecionando...</span>';
                        
                        setTimeout(() => {
                            window.location.href = '/login.html?error=auth_failed';
                        }, 2000);
                    }
                }, 1500);
                
            } catch (error) {
                console.error('Erro:', error);
                statusMessage.innerHTML = '<span class="text-rose-400">Erro inesperado. Redirecionando...</span>';
                
                setTimeout(() => {
                    window.location.href = '/login.html?error=unknown';
                }, 2000);
            }
        });
    </script>
</body>
</html>
