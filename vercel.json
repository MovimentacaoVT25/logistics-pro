{
  "version": 2,
  "name": "fretes-vt25",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)",  "dest": "/js/$1"  },
    { "src": "/pages/(.*)", "dest": "/pages/$1" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}